    "./json": "./json.js",
    "./typescript": "./typescript.js",
    "./fp": "./fp.js"
  },
  "dependencies": {
    "@eslint/compat": "^2.0.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-chai-friendly": "^1.2.0",
    "eslint-plugin-cypress": "^6.4.0",
    "eslint-plugin-flowtype": "^8.0.3",
