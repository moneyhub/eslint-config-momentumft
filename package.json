{
  "name": "@mft/eslint-config-momentumft",
  "version": "12.0.1",
  "description": "Moneyhub ESLint configuration",
  "bin": {
    "mh-lint": "./bin/mh-lint",
    "mh-lint:fix": "./bin/mh-lint-fix"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 0",
